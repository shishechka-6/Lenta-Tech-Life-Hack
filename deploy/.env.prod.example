BACKEND_IMAGE=ghcr.io/OWNER/REPO/lenta-backend:latest
FRONTEND_IMAGE=ghcr.io/OWNER/REPO/lenta-frontend:latest

MODEL_PATH=/opt/lenta/models/best.pt

FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=8501
BACKEND_BIND=0.0.0.0
BACKEND_PORT=8000

LENTA_DEVICE=auto
LENTA_CONF=0.25
LENTA_IOU=0.5
LENTA_IMGSZ=1280
LENTA_MAX_UPLOAD_MB=2048
LENTA_JOB_WORKERS=1

REQUEST_TIMEOUT_SECONDS=3600
POLL_INTERVAL_SECONDS=2
BACKEND_TMPFS_SIZE=4g
